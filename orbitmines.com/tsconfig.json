{
  "compilerOptions": {
    "target": "ES2015",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "strictNullChecks": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@blueprintjs/core": ["./src/lib/blueprintjs"],
      "@blueprintjs/core/src/common": ["./src/lib/blueprintjs/common"],
      "@blueprintjs/core/src/hooks/hotkeys/hotkeyConfig": ["./src/lib/blueprintjs/hooks/hotkeys/hotkeyConfig"],
      "@blueprintjs/icons": ["./src/lib/blueprintjs"],
      "@blueprintjs/icons/src/generated/16px/blueprint-icons-16.ttf": ["./src/lib/blueprintjs/css/blueprint-icons-16.ttf"],
      "@blueprintjs/icons/src/generated/20px/blueprint-icons-20.ttf": ["./src/lib/blueprintjs/css/blueprint-icons-20.ttf"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    ".next/types/**/*.ts",
    "build/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "build"
  ]
}
